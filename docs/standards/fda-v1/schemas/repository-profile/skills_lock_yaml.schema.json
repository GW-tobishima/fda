{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/fda-v1/repository-profile/skills_lock_yaml.schema.json",
  "title": ".fda/skills.lock",
  "type": "object",
  "additionalProperties": false,
  "required": ["skills"],
  "properties": {
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    }
  }
}
