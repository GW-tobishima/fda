{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/fda-v1/delivery-registry/epic.schema.json",
  "title": "Epic",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "epic_id", "program_id", "title", "status", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "fda.epic.v1" },
    "epic_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "ready", "running", "ai_repair", "human_turn", "completed", "done", "superseded", "canceled"] },
    "case_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "planned_pr_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "decision_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "risk_summary": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
