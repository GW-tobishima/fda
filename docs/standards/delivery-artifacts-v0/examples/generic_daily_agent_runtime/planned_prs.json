        ]
      },
      "risk": {
        "level": "high",
        "summary": "既存AICX PoCのCLIやartifact pathを壊すと過去のreceipt検証が使えなくなる。",
        "mitigations": [
          "旧コマンド互換かdeprecated方針をHuman Decisionで決める",
          "AICX fixtureをgeneric boundary移行前後で比較する",
          "runtime codeは人間確認なしにmerge候補化しない"
        ]
      },
      "claim_ids": [
        "CLM-GDAR-003",
        "CLM-GDAR-004",
        "CLM-GDAR-005"
      ],
      "proof_strategy": [
        {
          "proof_id": "PRF-GDAR-005",
          "type": "compatibility_regression",
          "description": "AICX Study Botのdispatch、poll、grading、status相当の既存fixtureが移行後も同じ意味で通る。",
          "blocking": true,
          "expected_evidence": [
