      "expected_files": [
        "docs/standards/delivery-artifacts-v0/schemas/**",
        "docs/standards/delivery-artifacts-v0/artifact_catalog.md",
        "docs/standards/delivery-artifacts-v0/examples/generic_daily_agent_runtime/**"
      ],
      "auto_merge_candidate": false,
      "human_decision_dependencies": []
    },
    {
      "planned_pr_id": "PR-GDAR-002",
      "sequence": 2,
      "title": "generic maintain/status command boundary",
      "case_id": "CASE-GDAR-002",
      "purpose": "dispatch、event intake、catch-up、maintain、statusを単発commandとして安全に再実行できる境界へ落とす。",
      "scope": {
        "in": [
          "dispatch-if-due contract",
          "poll/action contract",
          "maintain command decision table",
          "status projection fields",
          "idempotency and failure classification fixtures"
        ],
        "out": [
          "daemon implementation",
          "Slack Socket Mode reconnect handling",
          "UI implementation"
        ]
      },
      "risk": {
        "level": "medium",
        "summary": "maintain commandが多責務化するとdispatchとactionの二重実行防止が曖昧になる。",
        "mitigations": [
          "run_stateの読み取り順とidempotency keyを先に固定する",
          "not_due、dispatch candidate、waiting_for_inbound、action_completed、failed、noopのfixtureを分ける"
        ]
      },
      "claim_ids": [
        "CLM-GDAR-002",
        "CLM-GDAR-003",
        "CLM-GDAR-005"
      ],
      "proof_strategy": [
        {
          "proof_id": "PRF-GDAR-003",
          "type": "idempotency_fixture",
          "description": "同一date/target/inputでdispatch/actionが二重実行されないfixtureを追加する。",
          "blocking": true,
          "expected_evidence": [
            "generic daily runtime fixture matrix",
            "maintenance receipt examples"
          ]
        },
        {
          "proof_id": "PRF-GDAR-004",
          "type": "status_projection_review",
          "description": "人間がJSONを直接読まずにcurrent state、last event、next action、artifact pathを確認できる。",
          "blocking": true,
          "expected_evidence": [
            "status report fixture",
            "runner explanation"
          ]
        }
      ],
      "acceptance_criteria": [
        "maintain/statusの責務境界がdocsまたはcontractに固定されている",
        "二重dispatchと二重actionを防ぐ証跡方針がある",
        "missing env、SDK不足、network、rate limit、thread not found、invalid inputが分類される"
      ],
      "expected_files": [
        "src/**",
        "docs/runtime/**",
        "docs/standards/delivery-artifacts-v0/examples/generic_daily_agent_runtime/**"
      ],
      "auto_merge_candidate": false,
      "human_decision_dependencies": [
        "HD-GDAR-001"
      ]
    },
    {
      "planned_pr_id": "PR-GDAR-003",
      "sequence": 3,
      "title": "migrate AICX Study Bot onto generic runtime boundary",
      "case_id": "CASE-GDAR-003",
      "purpose": "AICX Study Botの既存daily dispatch、thread poll、grading、daily-status相当の挙動をgeneric runtime boundary上へ移す。",
      "scope": {
