      "acceptance_criteria": [
        "AICX Study Botの既存挙動維持またはdeprecated方針が明示されている",
        "generic runtime boundary上でAICX adapterがどう呼ばれるか追跡できる",
        "互換性QAとfailure recoveryの証跡がある"
      ],
      "expected_files": [
