        {
          "proof_id": "PRF-GDAR-002",
          "type": "traceability_review",
          "description": "artifact_inventoryとrunner_explanationから生成物、入力、次actionを辿れる。",
          "blocking": true,
          "expected_evidence": [
            "docs/standards/delivery-artifacts-v0/examples/generic_daily_agent_runtime/artifact_inventory.json",
            "docs/standards/delivery-artifacts-v0/examples/generic_daily_agent_runtime/runner_explanation.json",
            "docs/standards/delivery-artifacts-v0/examples/generic_daily_agent_runtime/runtime_artifact_contracts.md"
          ]
        }
      ],
      "acceptance_criteria": [
        "run_state/receipt系artifactの汎用化対象が明示されている",
        "artifact_inventoryから計画成果物を辿れる",
