      "correct_choice": "B",
      "rationale": "実運用では通常ケースだけでなく、停止条件、人間確認、再実行経路を含む例外系の検証が必要です。",
      "scenario_tags": [
        "exception_handling",
        "human_check",
        "workflow_test"
      ]
    },
