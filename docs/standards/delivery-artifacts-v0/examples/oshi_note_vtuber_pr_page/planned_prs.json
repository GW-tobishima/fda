        "mitigations": [
          "本人確認済みVTuber / 事務所アカウントだけに紹介URL発行を限定する",
          "素材許諾範囲が未記録の素材をPRページやカードで使えないようにする",
          "停止、削除、表示名変更の受付導線を定義する"
        ]
      },
      "claim_ids": [
