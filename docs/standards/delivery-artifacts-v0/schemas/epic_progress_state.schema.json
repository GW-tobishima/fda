{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/epic_progress_state.schema.json",
  "title": "Epic Progress State",
  "description": "F2 Epic 継続ループ（fda continue --epic）が planned_prs.json と各 run の receipt から生成する、planned PR ごとの進捗状態。receipt は書き換えず read-only で投影する。これは非権威の判断支援 projection であり merge の証明ではない。自動化は本 artifact を merge 判定に使ってはならない（merge 可否は fda merge の merge gate が fail-closed で判定する）。",
  "type": "object",
  "required": [
    "schema_version",
    "advisory",
    "epic_id",
    "generated_at_unix",
    "prs",
    "summary",
    "scan_notes",
    "scan_errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "fda.epic_progress_state.v1"
    },
    "advisory": {
      "type": "string",
      "const": "この判定は非権威の提案であり、実装開始許可・merge 承認・merge の証明ではない"
    },
    "epic_id": { "type": "string", "minLength": 1 },
    "generated_at_unix": { "type": "integer", "minimum": 0 },
    "prs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "planned_pr_id",
          "sequence",
          "title",
          "status",
          "evidence",
          "reasons"
        ],
        "properties": {
          "planned_pr_id": { "type": "string", "minLength": 1 },
          "sequence": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "description": "human_approval_required は merge gate 到達済みで merge approval 未記録（fda decide 待ち）、merge_ready は承認済み・merge 実行待ち（fda merge --execute 待ち）。",
            "enum": [
              "not_started",
              "in_progress",
              "pr_open",
              "human_approval_required",
              "merge_ready",
              "merged",
              "blocked"
            ]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "reasons": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "description": "7 種の PR status を 5 バケットへ集計する。open=in_progress+pr_open、waiting_human=merge_ready+human_approval_required（人間の merge 承認 / 実行待ち）。",
      "required": [
        "merged",
        "open",
        "blocked",
        "waiting_human",
        "not_started"
      ],
      "properties": {
        "merged": { "type": "integer", "minimum": 0 },
        "open": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "waiting_human": { "type": "integer", "minimum": 0 },
        "not_started": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "scan_notes": {
      "type": "array",
      "description": "epic_id 突合（不一致・欠落）で状態根拠から除外した receipt の記録。",
      "items": { "type": "string", "minLength": 1 }
    },
    "scan_errors": {
      "type": "array",
      "description": "parse error 等で読めなかった receipt の記録。fail-soft で走査は継続し verdict には影響しない（安全性は実 merge gate 側で担保）。",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
