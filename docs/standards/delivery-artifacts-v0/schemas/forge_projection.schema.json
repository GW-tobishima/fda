{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/forge_projection.schema.json",
  "title": "Forge Projection",
  "type": "object",
  "required": [
    "schema_version",
    "program_id",
    "epic_id",
    "source_artifacts",
    "claim_contracts",
    "proof_obligations",
    "promotion_readiness",
    "gate_requirements"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "forge_projection.v0" },
    "program_id": { "type": "string", "minLength": 1 },
    "epic_id": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "claim_contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "type", "statement", "blocking", "case_ids", "planned_pr_ids", "proof_obligations"],
        "properties": {
          "claim_id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["functional", "non_functional", "security", "ux", "operational", "contract"] },
          "statement": { "type": "string", "minLength": 1 },
          "blocking": { "type": "boolean" },
          "case_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "planned_pr_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "proof_obligations": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
        },
        "additionalProperties": false
      }
    },
    "proof_obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["proof_id", "claim_id", "type", "required_evidence", "blocking", "owner_agent", "validation_method"],
        "properties": {
          "proof_id": { "type": "string", "minLength": 1 },
          "claim_id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "required_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
          "blocking": { "type": "boolean" },
          "owner_agent": { "type": "string", "minLength": 1 },
          "validation_method": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "promotion_readiness": {
      "type": "object",
      "required": ["verdict", "reason", "evaluated_at", "gate_inputs_ready"],
      "properties": {
        "verdict": { "type": "string", "enum": ["not_evaluated", "hold", "reject", "promote"] },
        "reason": { "type": "string", "minLength": 1 },
        "evaluated_at": { "type": ["string", "null"] },
        "gate_inputs_ready": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "gate_requirements": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
  },
  "additionalProperties": false
}
