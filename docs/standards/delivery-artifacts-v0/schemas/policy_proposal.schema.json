{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/policy_proposal.schema.json",
  "title": "Policy Proposal (delegation contract 逆提案)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_unix",
    "artifacts_root",
    "min_occurrences",
    "scanned_runs",
    "candidate_count",
    "candidates"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "fda.policy_proposal.v1" },
    "generated_at_unix": { "type": "integer", "minimum": 0 },
    "artifacts_root": { "type": "string", "minLength": 1 },
    "min_occurrences": { "type": "integer", "minimum": 1 },
    "scanned_runs": { "type": "integer", "minimum": 0 },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proposed_rule_id",
          "decision_type",
          "answer",
          "occurrences",
          "match_summary_keywords",
          "enacted_from",
          "summary_signature"
        ],
        "properties": {
          "proposed_rule_id": { "type": "string", "minLength": 1 },
          "decision_type": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 },
          "occurrences": { "type": "integer", "minimum": 1 },
          "match_summary_keywords": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "enacted_from": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "summary_signature": { "type": "string" }
        }
      }
    }
  }
}
