{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/external_pr_receipt.schema.json",
  "title": "External PR Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "program_id",
    "epic_id",
    "source_packet_id",
    "target_repo",
    "planned_pr_id",
    "actual_pr_url",
    "status",
    "checks",
    "evidence",
    "human_decisions_resolved",
    "open_issues",
    "scope_disposition",
    "target_pr",
    "changed_files",
    "acceptance_criteria_status",
    "validation",
    "rollback_plan"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "external_pr_receipt.v0" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "epic_id": { "type": "string", "minLength": 1 },
    "source_packet_id": { "type": "string", "minLength": 1 },
    "target_repo": { "type": "string", "minLength": 1 },
    "planned_pr_id": { "type": "string", "minLength": 1 },
    "actual_pr_url": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["opened", "merged", "blocked", "rejected"]
    },
    "checks": {
      "type": "object",
      "required": ["tests", "lint", "security"],
      "properties": {
        "tests": {
          "type": "string",
          "enum": ["passed", "failed", "not_applicable", "not_run"]
        },
        "lint": {
          "type": "string",
          "enum": ["passed", "failed", "not_applicable", "not_run"]
        },
        "security": {
          "type": "string",
          "enum": ["passed", "failed", "not_applicable", "not_run"]
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "human_decisions_resolved": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "open_issues": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "scope_disposition": {
      "type": "object",
      "required": [
        "kind",
        "closure_recommendation",
        "affected_planned_pr_ids",
        "summary"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["within_scope", "scope_deviation"]
        },
        "closure_recommendation": {
          "type": "string",
          "enum": [
            "close_planned_pr",
            "do_not_close_planned_pr",
            "manual_review_required"
          ]
        },
        "affected_planned_pr_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "summary": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": { "const": "scope_deviation" }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "closure_recommendation": {
                "enum": [
                  "do_not_close_planned_pr",
                  "manual_review_required"
                ]
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "target_pr": {
      "type": "object",
      "required": ["url", "number", "head_sha", "state"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "number": { "type": ["integer", "null"], "minimum": 1 },
        "head_sha": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "enum": ["draft", "open", "merged", "closed"] }
      },
      "additionalProperties": false
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance_criteria_status": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion", "status", "evidence"],
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail", "not_applicable"] },
          "evidence": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail", "not_run"] },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "security_privacy_legal_review": { "type": "string" },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "merged" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "target_pr": {
            "properties": {
              "state": { "const": "merged" }
            },
            "required": ["state"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "opened" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "target_pr": {
            "properties": {
              "state": { "enum": ["draft", "open"] }
            },
            "required": ["state"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "rejected" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "target_pr": {
            "properties": {
              "state": { "const": "closed" }
            },
            "required": ["state"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "blocked" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "target_pr": {
            "properties": {
              "state": { "enum": ["draft", "open", "closed"] }
            },
            "required": ["state"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
