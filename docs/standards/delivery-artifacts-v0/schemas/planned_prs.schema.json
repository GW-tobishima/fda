{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/planned_prs.schema.json",
  "title": "Planned PRs",
  "type": "object",
  "required": ["schema_version", "program_id", "epic_id", "source_requirements", "planned_prs"],
  "properties": {
    "schema_version": { "type": "string", "const": "forge_delivery.planned_prs.v0" },
    "program_id": { "type": "string", "minLength": 1 },
    "epic_id": { "type": "string", "minLength": 1 },
    "source_requirements": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "planned_prs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "planned_pr_id",
          "sequence",
          "title",
          "case_id",
          "purpose",
          "scope",
          "risk",
          "claim_ids",
          "proof_strategy",
          "acceptance_criteria",
          "expected_files",
          "auto_merge_candidate",
          "human_decision_dependencies"
        ],
        "properties": {
          "planned_pr_id": { "type": "string", "minLength": 1 },
          "sequence": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "case_id": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "scope": {
            "type": "object",
            "required": ["in", "out"],
            "properties": {
              "in": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "out": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": false
          },
          "risk": {
            "type": "object",
            "required": ["level", "summary", "mitigations"],
            "properties": {
              "level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
              "summary": { "type": "string", "minLength": 1 },
              "mitigations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": false
          },
          "claim_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
          "proof_strategy": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["proof_id", "type", "description", "blocking", "expected_evidence"],
              "properties": {
                "proof_id": { "type": "string", "minLength": 1 },
                "type": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "blocking": { "type": "boolean" },
                "expected_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              },
              "additionalProperties": false
            }
          },
          "acceptance_criteria": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
          "expected_files": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "auto_merge_candidate": { "type": "boolean" },
          "human_decision_dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
