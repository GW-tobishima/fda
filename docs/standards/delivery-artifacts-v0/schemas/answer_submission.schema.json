{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/answer_submission.schema.json",
  "title": "AICX Fixture Answer Submission",
  "type": "object",
  "required": [
    "schema_version",
    "submission_id",
    "quiz_set_id",
    "submitted_for_date",
    "source",
    "answers"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "aicx.answer_submission.v0" },
    "submission_id": { "type": "string", "minLength": 1 },
    "quiz_set_id": { "type": "string", "minLength": 1 },
    "submitted_for_date": { "type": "string", "format": "date" },
    "source": {
      "type": "string",
      "enum": ["fixture_answer_grading", "slack_reply_fixture_grading", "slack_socket_mode_grading", "slack_thread_poll_grading"]
    },
    "source_event_id": { "type": "string", "minLength": 1 },
    "answers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 60,
      "items": {
        "type": "object",
        "required": ["question_id", "selected_choice"],
        "properties": {
          "question_id": { "type": "string", "minLength": 1 },
          "selected_choice": { "type": "string", "enum": ["A", "B", "C", "D"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
