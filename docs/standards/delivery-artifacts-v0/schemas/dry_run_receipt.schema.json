{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/dry_run_receipt.schema.json",
  "title": "MCP Dry-run Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "plan_id",
    "invocation_id",
    "provider",
    "mcp_server_command",
    "cwd",
    "status",
    "started_at",
    "completed_at",
    "target_repo_mutated",
    "expected_tools",
    "detected_tools",
    "missing_tools",
    "checks",
    "evidence_links"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "fda.mcp_dry_run_receipt.v0" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "invocation_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "enum": ["codex", "claude", "other"] },
    "mcp_server_command": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "cwd": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["succeeded", "failed", "blocked", "adapter_unavailable"] },
    "started_at": { "type": "string", "minLength": 1 },
    "completed_at": { "type": "string", "minLength": 1 },
    "target_repo_mutated": { "type": "boolean", "const": false },
    "expected_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "detected_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_id", "status", "summary"],
        "properties": {
          "check_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
          "summary": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "evidence_links": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "succeeded" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "missing_tools": { "maxItems": 0 },
          "checks": {
            "items": {
              "properties": { "status": { "const": "pass" } },
              "required": ["status"]
            }
          }
        },
        "required": ["missing_tools", "checks"]
      }
    }
  ],
  "additionalProperties": false
}
