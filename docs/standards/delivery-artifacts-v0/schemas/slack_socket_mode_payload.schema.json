            "text": { "type": "string", "minLength": 1 },
            "ts": { "type": "string", "minLength": 1 },
            "thread_ts": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "source": { "type": "string", "const": "manual_socket_mode_fixture" }
  },
  "additionalProperties": false
}
