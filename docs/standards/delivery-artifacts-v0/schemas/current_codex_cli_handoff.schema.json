{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/current_codex_cli_handoff.schema.json",
  "title": "Current Codex CLI Handoff",
  "type": "object",
  "required": [
    "schema_version",
    "handoff_id",
    "program_id",
    "epic_id",
    "planned_pr_id",
    "executor",
    "target_repo",
    "status",
    "role_switch",
    "profile_gate",
    "human_decision_guard",
    "source_artifacts",
    "scope_in",
    "scope_out",
    "required_checks",
    "expected_evidence",
    "forbidden_actions",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "fda.current_codex_cli_handoff.v0" },
    "handoff_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "epic_id": { "type": "string", "minLength": 1 },
    "planned_pr_id": { "type": "string", "minLength": 1 },
    "executor": { "type": "string", "const": "current_codex_cli" },
    "target_repo": {
      "type": "object",
      "required": ["cwd", "exists"],
      "properties": {
        "cwd": { "type": "string", "minLength": 1 },
        "exists": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "status": { "type": "string", "enum": ["ready", "blocked"] },
    "role_switch": {
      "type": "object",
      "required": ["from_role", "to_role", "requires_checkpoint", "requires_handoff"],
      "properties": {
        "from_role": { "type": "string", "minLength": 1 },
        "to_role": { "type": "string", "const": "implementer" },
        "requires_checkpoint": { "type": "boolean", "const": true },
        "requires_handoff": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "profile_gate": {
      "type": "object",
      "required": ["required", "created_or_verified", "required_files"],
      "properties": {
        "required": { "type": "boolean", "const": true },
        "created_or_verified": { "type": "boolean" },
        "required_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "human_decision_guard": {
      "type": "object",
      "required": ["unresolved_decision_ids", "non_approval_decision_ids"],
      "properties": {
        "unresolved_decision_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "non_approval_decision_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope_in": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope_out": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "expected_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "target_repo": {
            "properties": { "exists": { "const": true } },
            "required": ["exists"]
          },
          "profile_gate": {
            "properties": { "created_or_verified": { "const": true } },
            "required": ["created_or_verified"]
          },
          "human_decision_guard": {
            "properties": {
              "unresolved_decision_ids": { "maxItems": 0 },
              "non_approval_decision_ids": { "maxItems": 0 }
            },
            "required": ["unresolved_decision_ids", "non_approval_decision_ids"]
          }
        },
        "required": ["target_repo", "profile_gate", "human_decision_guard"]
      }
    }
  ],
  "additionalProperties": false
}
