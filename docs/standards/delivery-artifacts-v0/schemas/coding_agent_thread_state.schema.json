{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/coding_agent_thread_state.schema.json",
  "title": "Coding Agent Thread State",
  "type": "object",
  "required": [
    "schema_version",
    "thread_state_id",
    "provider",
    "role",
    "status",
    "started_from_invocation_id",
    "planned_pr_id",
    "cwd",
    "continuation_tool_name",
    "current_turn",
    "repair_attempt_count",
    "last_receipt_id",
    "summary",
    "open_items",
    "evidence_links"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "fda.coding_agent_thread_state.v0" },
    "thread_state_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "enum": ["codex", "claude", "other"] },
    "role": { "type": "string", "enum": ["implementer", "functional_qa", "security_qa"] },
    "status": { "type": "string", "enum": ["active", "waiting_for_reply", "completed", "blocked", "superseded"] },
    "started_from_invocation_id": { "type": "string", "minLength": 1 },
    "planned_pr_id": { "type": "string", "minLength": 1 },
    "actual_pr_url": { "type": ["string", "null"] },
    "cwd": { "type": "string", "minLength": 1 },
    "thread_id": { "type": ["string", "null"] },
    "continuation_tool_name": { "type": ["string", "null"] },
    "current_turn": { "type": "integer", "minimum": 0 },
    "repair_attempt_count": { "type": "integer", "minimum": 0 },
    "failure_classification": { "type": ["string", "null"] },
    "last_prompt_artifact": { "type": ["string", "null"] },
    "last_receipt_id": { "type": ["string", "null"] },
    "summary": { "type": "string", "minLength": 1 },
    "open_items": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_links": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
