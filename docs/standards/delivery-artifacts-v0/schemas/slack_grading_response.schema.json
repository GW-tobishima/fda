{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/slack_grading_response.schema.json",
  "title": "AICX Slack Grading Response",
  "type": "object",
  "required": [
    "schema_version",
    "response_id",
    "quiz_set_id",
    "reply_event_id",
    "submission_id",
    "grading_report_id",
    "study_recommendation_id",
    "generated_for_date",
    "delivery_channel",
    "thread_ts",
    "response_text",
    "total_questions",
    "correct_count",
    "accuracy",
    "recommended_pages",
    "slack_send_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "aicx.slack_grading_response.v0" },
    "response_id": { "type": "string", "minLength": 1 },
    "quiz_set_id": { "type": "string", "minLength": 1 },
    "reply_event_id": { "type": "string", "minLength": 1 },
    "submission_id": { "type": "string", "minLength": 1 },
    "grading_report_id": { "type": "string", "minLength": 1 },
    "study_recommendation_id": { "type": "string", "minLength": 1 },
    "generated_for_date": { "type": "string", "format": "date" },
    "delivery_channel": { "type": "string", "const": "slack" },
    "thread_ts": { "type": "string", "minLength": 1 },
    "response_text": { "type": "string", "minLength": 1 },
    "total_questions": { "type": "integer", "minimum": 1 },
    "correct_count": { "type": "integer", "minimum": 0 },
    "accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
    "recommended_pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["topic_id", "label", "page_ranges", "reason"],
        "properties": {
          "topic_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "page_ranges": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["from", "to"],
              "properties": {
                "from": { "type": "integer", "minimum": 1 },
                "to": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": false
            }
          },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "slack_send_required": { "type": "boolean" }
  },
  "additionalProperties": false
}
