{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/slack_reply_event.schema.json",
  "title": "AICX Slack Reply Event Fixture",
  "type": "object",
  "required": [
    "schema_version",
    "reply_event_id",
    "quiz_set_id",
    "message_id",
    "delivery_channel",
    "channel_id",
    "user_id",
    "thread_ts",
    "event_ts",
    "text",
    "source"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "aicx.slack_reply_event_fixture.v0" },
    "reply_event_id": { "type": "string", "minLength": 1 },
    "quiz_set_id": { "type": "string", "minLength": 1 },
    "message_id": { "type": "string", "minLength": 1 },
    "delivery_channel": { "type": "string", "const": "slack" },
    "channel_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "thread_ts": { "type": "string", "minLength": 1 },
    "event_ts": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "enum": ["manual_fixture", "socket_mode_event", "thread_poll_event"] },
    "socket_envelope_id": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
