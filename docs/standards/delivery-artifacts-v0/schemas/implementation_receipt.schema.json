{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/implementation_receipt.schema.json",
  "title": "Implementation Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "program_id",
    "epic_id",
    "planned_pr_id",
    "provider",
    "mcp_server_command",
    "cwd",
    "status",
    "started_at",
    "completed_at",
    "dry_run_gate",
    "actual_pr_url",
    "changed_files",
    "tests",
    "scope_drift",
    "input_artifacts",
    "output_artifacts",
    "evidence_links",
    "next_action",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "fda.implementation_receipt.v0" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "epic_id": { "type": "string", "minLength": 1 },
    "planned_pr_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "enum": ["codex", "claude", "other"] },
    "mcp_server_command": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "cwd": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "failed", "blocked", "adapter_unavailable"]
    },
    "started_at": { "type": "string", "minLength": 1 },
    "completed_at": { "type": "string", "minLength": 1 },
    "thread_id": { "type": ["string", "null"] },
    "dry_run_gate": {
      "type": "object",
      "required": ["status", "issues", "evidence_links"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "issues": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence_links": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "actual_pr_url": { "type": ["string", "null"] },
    "changed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "status", "summary"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["passed", "failed", "not_run"] },
          "summary": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "scope_drift": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "input_artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "output_artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "evidence_links": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "next_action": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "succeeded" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "actual_pr_url": { "type": "string", "minLength": 1 },
          "tests": {
            "items": {
              "properties": { "status": { "const": "passed" } },
              "required": ["status"]
            }
          },
          "dry_run_gate": {
            "properties": {
              "status": { "const": "succeeded" },
              "issues": { "maxItems": 0 }
            },
            "required": ["status", "issues"]
          }
        },
        "required": ["actual_pr_url", "tests", "dry_run_gate"]
      }
    }
  ],
  "additionalProperties": false
}
