{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/quiz_set.schema.json",
  "title": "AICX Fixture Quiz Set",
  "type": "object",
  "required": [
    "schema_version",
    "quiz_set_id",
    "program_id",
    "epic_id",
    "generated_for_date",
    "timezone",
    "delivery_time",
    "source_mode",
    "pdf_ingest_used",
    "slack_used",
    "line_used",
    "answer_format",
    "study_window",
    "topic_scope",
    "question_count",
    "questions"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "aicx.quiz_set.v0" },
    "quiz_set_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "epic_id": { "type": "string", "minLength": 1 },
    "generated_for_date": { "type": "string", "format": "date" },
    "timezone": { "type": "string", "minLength": 1 },
    "delivery_time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
    "source_mode": { "type": "string", "const": "manual_fixture" },
    "pdf_ingest_used": { "type": "boolean", "const": false },
    "slack_used": { "type": "boolean", "const": false },
    "line_used": { "type": "boolean", "const": false },
    "answer_format": { "type": "string", "const": "multiple_choice_a_d" },
    "study_window": {
      "type": "object",
      "required": ["week_id", "date_from", "date_to", "study_pages", "focus_topics"],
      "properties": {
        "week_id": { "type": "string", "minLength": 1 },
        "date_from": { "type": "string", "format": "date" },
        "date_to": { "type": "string", "format": "date" },
        "study_pages": {
          "type": "array",
          "items": { "$ref": "#/$defs/page_range" }
        },
        "focus_topics": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "topic_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["topic_id", "label", "page_ranges"],
        "properties": {
          "topic_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "page_ranges": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/page_range" }
          }
        },
        "additionalProperties": false
      }
    },
    "question_count": { "type": "integer", "minimum": 1, "maximum": 60 },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 60,
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "topic_id",
          "topic_label",
          "page_ranges",
          "source",
          "difficulty",
          "prompt",
          "choices",
          "correct_choice",
          "rationale"
        ],
        "properties": {
          "question_id": { "type": "string", "minLength": 1 },
          "topic_id": { "type": "string", "minLength": 1 },
          "topic_label": { "type": "string", "minLength": 1 },
          "page_ranges": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/page_range" }
          },
          "source": {
            "type": "string",
            "enum": ["manual_fixture_topic_map", "question_bank_fixture"]
          },
          "difficulty": { "type": "string", "enum": ["practical"] },
          "prompt": { "type": "string", "minLength": 1 },
          "choices": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["choice", "text"],
              "properties": {
                "choice": { "type": "string", "enum": ["A", "B", "C", "D"] },
                "text": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "correct_choice": { "type": "string", "enum": ["A", "B", "C", "D"] },
          "rationale": { "type": "string", "minLength": 1 },
          "scenario_tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "page_range": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "integer", "minimum": 1 },
        "to": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
