{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/delivery-artifacts-v0/artifact_inventory.schema.json",
  "title": "Artifact Inventory",
  "type": "object",
  "required": ["schema_version", "generated_at_unix_seconds", "artifacts", "groups"],
  "properties": {
    "schema_version": { "type": "string", "const": "fda.artifact_inventory.v0" },
    "generated_at_unix_seconds": { "type": "integer", "minimum": 0 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "artifact_type",
          "title",
          "producer_agent",
          "related_program_id",
          "related_epic_id",
          "latest_version",
          "preview_summary",
          "path_or_url",
          "evidence_links",
          "created_at_unix_seconds",
          "updated_at_unix_seconds"
        ],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "artifact_type": {
            "type": "string",
            "enum": [
              "epic_delivery_plan",
              "case_graph",
              "task_graph",
              "planned_prs",
              "ato_cli_materialization_plan",
              "ato_cli_commands",
              "autonomy_contract",
              "human_decision_packet",
              "ato_summary_preview",
              "forge_projection",
              "forge_promotion_receipt",
              "target_repo_profile",
              "current_codex_cli_handoff",
              "review_agent_gate",
              "planned_pr_execution_packet",
              "mcp_agent_invocation_plan",
              "mcp_tool_call_receipt",
              "dry_run_receipt",
              "implementation_receipt",
              "live_execution_evidence",
              "end_to_end_receipt",
              "status_summary",
              "output_hub",
              "output_hub_receipt",
              "decision_inbox",
              "execution_status",
              "ato_state_receipt",
              "coding_agent_thread_state",
              "agent_role_policy",
              "external_pr_receipt",
              "notification_request",
              "notification_receipt",
              "merge_gate_summary",
              "qa_receipt",
              "functional_qa_receipt",
              "security_qa_receipt",
              "repair_receipt",
              "external_pr_receipt_schema",
              "evidence_return_packet",
              "evidence_return_packet_schema",
              "generic_run_state",
              "generic_receipt",
              "runtime_artifact_contracts",
              "runner_explanation",
              "agent_prompt",
              "validation_report",
              "development_handoff",
              "unit_test_report",
              "self_review_report",
              "review_packet",
              "study_schedule",
              "topic_map",
              "question_bank_fixture",
              "quiz_set",
              "quiz_prompt",
              "answer_submission",
              "grading_report",
              "study_recommendation",
              "slack_outbound_message",
              "slack_delivery_receipt",
              "slack_reply_event",
              "slack_grading_response",
              "slack_grading_delivery_receipt",
              "slack_socket_mode_payload",
              "slack_reply_intake_receipt",
              "slack_thread_poll_receipt",
              "maintenance_receipt",
              "daily_run_state",
              "daily_operation_runbook",
              "adaptive_plan"
            ]
          },
          "title": { "type": "string", "minLength": 1 },
          "producer_agent": { "type": "string", "minLength": 1 },
          "related_program_id": { "type": "string", "minLength": 1 },
          "related_epic_id": { "type": "string", "minLength": 1 },
          "related_case_ids": { "type": "array", "items": { "type": "string" } },
          "related_task_ids": { "type": "array", "items": { "type": "string" } },
          "latest_version": { "type": "string", "minLength": 1 },
          "preview_summary": { "type": "string", "minLength": 1 },
          "path_or_url": { "type": "string", "minLength": 1 },
          "open_in_editor_link": { "type": ["string", "null"] },
          "open_in_browser_link": { "type": ["string", "null"] },
          "diff_link": { "type": ["string", "null"] },
          "evidence_links": { "type": "array", "items": { "type": "string" } },
          "created_at_unix_seconds": { "type": "integer", "minimum": 0 },
          "updated_at_unix_seconds": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group_id", "title", "artifact_ids"],
        "properties": {
          "group_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "artifact_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
